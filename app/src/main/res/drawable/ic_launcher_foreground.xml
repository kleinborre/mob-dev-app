<?xml version="1.0" encoding="utf-8"?>
<!--
    CalorEase Launcher Icon — Foreground Layer
    Bold capital "C" in white — Poppins Bold style
    Transparent background (gradient comes from ic_launcher_background.xml)

    Adaptive Icon sizing:
      Canvas    = 108 x 108 dp
      Safe zone = 66 x 66 dp (centered at 54,54 → from 21,21 to 87,87)
      Max outer radius from center = 33 dp

    Arc math (all values in viewport units, center at 54,54):
      Arc radius (stroke center) = 25 dp  → outer edge = 25+6 = 31 dp ✓ (within 33 dp safe zone)
      Stroke width               = 12 dp
      Opening angle              = ±50° from the right horizontal

      Start (bottom of C gap):
        x = 54 + 25×cos(50°) = 54 + 16.07 = 70
        y = 54 + 25×sin(50°) = 54 + 19.15 = 73

      End (top of C gap):
        x = 70
        y = 54 − 25×sin(50°) = 54 − 19.15 = 35

      Arc: clockwise (sweep-flag=1), large arc (large-arc-flag=1)
      → sweeps 260° through bottom → left → top
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M 70,73 A 25,25,0,1,1,70,35"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="12"
        android:strokeLineCap="round" />

</vector>