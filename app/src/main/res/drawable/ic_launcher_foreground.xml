<?xml version="1.0" encoding="utf-8"?>
<!--
    CalorEase Launcher Icon — Foreground Layer
    Bold capital "C" in white — Poppins Bold style
    Transparent background (gradient comes from ic_launcher_background.xml)

    Adaptive Icon sizing:
      Canvas    = 108 x 108 dp
      Safe zone = 66 x 66 dp (center 54,54 → bounds 21–87)
      Target    = ~65% of safe zone radius = ~21dp outer edge from center

    Arc math (center at 54,54):
      Arc radius (stroke center) = 18 dp
      Stroke width               =  9 dp
      Outer edge from center     = 18 + 4.5 = 22.5 dp  ✓ (well within 33dp limit)
      Opening angle              = ±50° from right horizontal

      Start (bottom of C gap):  x = 54 + 18×cos(50°) = 66,  y = 54 + 18×sin(50°) = 68
      End   (top of C gap):     x = 66,                      y = 54 − 18×sin(50°) = 40

      Clockwise sweep (sweep-flag=1), large arc (large-arc-flag=1) = 260° arc
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M 66,68 A 18,18,0,1,1,66,40"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />

</vector>