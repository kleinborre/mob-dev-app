<?xml version="1.0" encoding="utf-8"?>
<!--
    CalorEase Launcher Icon — Foreground Layer
    Bold capital "C" in white — Poppins Bold style
    Transparent background (background color comes from ic_launcher_background.xml)

    Arc math (viewBox 108x108, center 54,54):
      Arc radius (stroke center) = 29dp
      Start point = (73, 76) → 50° below horizontal right
      End point   = (73, 32) → 50° above horizontal right
      Arc spans 260° going clockwise through bottom → left → top
      sweep-flag=1, large-arc-flag=1
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M 73,76 A 29,29,0,1,1,73,32"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="16"
        android:strokeLineCap="round" />

</vector>