<?xml version="1.0" encoding="utf-8"?>
<!--
    CalorEase Launcher Icon — Background Layer
    Diagonal gradient: DeepTealLight (#009BAA) → DeepTealDark (#004E5B)
    Matches the app's primary brand color from Color.kt
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0" android:color="#FF009BAA" />
                <item android:offset="1.0" android:color="#FF004E5B" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
